{
  "manifest_version": 3,
  "name": "Synapse - Your Second Brain",
  "version": "0.1.0",
  "description": "A privacy-first knowledge graph built passively from your browsing. 100% local.",
  "homepage_url": "https://github.com/ManeeshJupalle/Synapse",
  "permissions": ["storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "src/dashboard/index.html"
  },
  "action": {
    "default_title": "Synapse"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "models/*", "wasm/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
